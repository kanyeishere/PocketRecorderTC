prefix=/i/repos/Recorder/Recorder/lib/native/ffmpeg-minimal-lgpl-shared/ffmpeg-minimal-win64-lgpl-shared
exec_prefix=${prefix}
libdir=/i/repos/Recorder/Recorder/lib/native/ffmpeg-minimal-lgpl-shared/ffmpeg-minimal-win64-lgpl-shared/lib
includedir=/i/repos/Recorder/Recorder/lib/native/ffmpeg-minimal-lgpl-shared/ffmpeg-minimal-win64-lgpl-shared/include

Name: libavdevice
Description: FFmpeg device handling library
Version: 62.3.102
Requires: 
